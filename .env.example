# Local development
APP_ENV=local
WEBUI_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000/api

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=product_sourcing
POSTGRES_USER=product_sourcing
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://product_sourcing:change-me@localhost:5432/product_sourcing
CONTRACTS_DATABASE_URL=postgresql+psycopg://product_sourcing:change-me@localhost:5433/product_sourcing_contracts

# Broker / worker
REDIS_URL=redis://localhost:6379/0
WORKER_SERVICE_NAME=agent-worker
AUTO_PROCESS_SEARCH_TASKS=true
AUTO_PROCESS_SUPPLIER_CONTACT_TASKS=true
AUTO_PROCESS_CONTRACT_TASKS=true

# Model provider
MODEL_PROVIDER=local_demo
MODEL_NAME=browser-extraction-v0
MODEL_API_BASE_URL=
MODEL_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# Docker backend/worker use host Ollama by default on Windows.
# Set DOCKER_OLLAMA_BASE_URL=http://ollama:11434 if you intentionally keep models in the compose Ollama container.
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SECONDS=120

# Browser MCP
BROWSER_PROVIDER=playwright_mcp
BROWSER_MCP_SERVICE_NAME=browser-mcp
BROWSER_MCP_URL=
BROWSER_MCP_COMMAND=npx.cmd
BROWSER_MCP_ARGS=--yes @playwright/mcp@latest --headless --isolated --executable-path "C:\Program Files\Google\Chrome\Application\chrome.exe"
BROWSER_ALLOWED_DOMAINS=localhost,127.0.0.1,supplier-site
DOCKER_BROWSER_ALLOWED_DOMAINS=supplier-site,localhost,127.0.0.1
BROWSER_RESEARCH_MODE=site
BROWSER_ALLOW_PUBLIC_INTERNET=false
INTERNET_SEARCH_URL_TEMPLATE=https://www.adafruit.com/search?q={query}
INTERNET_SEARCH_RESULT_LIMIT=5
WEB_SEARCH_PROVIDER=multi
WEB_SEARCH_ENGINES=duckduckgo:https://duckduckgo.com/html/,searxng:http://localhost:8888/search
WEB_SEARCH_URL=https://duckduckgo.com/html/
WEB_SEARCH_RESULT_LIMIT=20
AI_SEARCH_QUERY_COUNT=3
AI_SEARCH_CANDIDATE_LIMIT=8
SEARCH_CONTACT_ENRICHMENT_PAGES=1

# Email connector
EMAIL_CONNECTOR_PROVIDER=smtp
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=product-sourcing-agent@example.test
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
EMAIL_TIMEOUT_SECONDS=30
EMAIL_INBOUND_PROVIDER=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_INBOUND_SYNC_LIMIT=20
AUTO_SYNC_GMAIL_INBOUND=true
GMAIL_INBOUND_SYNC_INTERVAL_SECONDS=30
DOCKER_EMAIL_SMTP_HOST=mailpit
DOCKER_EMAIL_SMTP_PORT=1025
DOCKER_EMAIL_SMTP_USER=
DOCKER_EMAIL_SMTP_PASSWORD=
DOCKER_EMAIL_FROM=product-sourcing-agent@example.test
DOCKER_EMAIL_USE_TLS=false
DOCKER_EMAIL_USE_SSL=false

# Telegram connector
TELEGRAM_CONNECTOR_PROVIDER=telegram_bot
TELEGRAM_BOT_TOKEN=telegram-placeholder-not-used
TELEGRAM_CHAT_ID=telegram-placeholder-chat-not-used
TELEGRAM_TIMEOUT_SECONDS=30

# Controlled E2E supplier contour
TEST_SUPPLIER_SITE_URL=http://localhost:8088
DOCKER_TEST_SUPPLIER_SITE_URL=http://supplier-site
TEST_SUPPLIER_EMAIL=supplier-e2e@example.test
TEST_SUPPLIER_TELEGRAM=@supplier_e2e_test

# Feature flags
ALLOW_PRODUCTS_WITHOUT_CONTACTS=false
